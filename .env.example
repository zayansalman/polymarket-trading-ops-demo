# Copy to .env locally (gitignored).

DATA_DIR=./data
DB_PATH=./data/btc_5m_lab.db

# Local unauthenticated dashboard bind address.
# Keep 127.0.0.1 unless you deliberately want LAN/container access.
DASHBOARD_SERVER_NAME=127.0.0.1
DASHBOARD_SERVER_PORT=7860

# Active execution target. Paper is the only supported mode in this build.
BTC_BOT_MODE=paper
BTC_PAPER_MIN_TRADE_USD=1
BTC_PAPER_MAX_TRADE_USD=5
BTC_PAPER_TICK_SECONDS=5
BTC_PAPER_ENTRY_EDGE_MIN=0.045
BTC_PAPER_MIN_CONFIDENCE=0.62
BTC_PAPER_TARGET_RETURN=0.10
BTC_PAPER_STOP_RETURN=-0.08
BTC_PAPER_TIME_EXIT_SECONDS=45

# Optional exported Polymarket CSV used only for sizing context.
BTC_HISTORY_CSV_PATH=./data/polymarket_history.csv
